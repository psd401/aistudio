# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-e2e/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example for documentation)
.env*
!.env.example

# OpenWiki local config/secrets (canonical location is ~/.openwiki/.env; this
# guards against an accidental in-repo .openwiki/ holding a provider API key).
# The generated openwiki/ wiki tree itself IS committed and is not ignored.
.openwiki/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# swc
.swc/

# playwright
/test-results/
/playwright-report/
/playwright/.cache/
/tests/e2e/screenshots/
/tests/e2e/videos/
/.playwright-mcp/

# Local scratch / scripts/db/sync-from-dev.ts dump output (may contain dev data)
/tmp/

# Python
__pycache__/

# CDK Lambda bundling artifacts (covers database/lambda and any future lambdas)
infra/**/package-lock.json

# Claude agent internal state
.claude/agent-memory/
.claude/worktrees/
docs/learnings/.evolve-state.json
tests/e2e/.auth/
