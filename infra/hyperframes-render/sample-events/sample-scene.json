{
  "html": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <!-- REQUIRED: viewport must match the composition dimensions. -->\n    <meta name=\"viewport\" content=\"width=1920, height=1080\" />\n    <title>PSD HyperFrames Smoke</title>\n    <style>\n      * {\n        margin: 0;\n        padding: 0;\n        box-sizing: border-box;\n      }\n      html,\n      body {\n        width: 1920px;\n        height: 1080px;\n        overflow: hidden;\n        background: #0b1f3a;\n        font-family: \"Inter\", system-ui, sans-serif;\n      }\n      /* Root #stage carries data-composition-id + data-duration (total). */\n      #stage {\n        position: relative;\n        width: 1920px;\n        height: 1080px;\n        overflow: hidden;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        background: linear-gradient(135deg, #0b1f3a 0%, #123a6b 60%, #1d5aa8 100%);\n      }\n      /* REQUIRED: timed clips start hidden; the framework toggles visibility\n         from data-start/data-duration. Never toggle visibility in script. */\n      .clip {\n        position: absolute;\n        inset: 0;\n        visibility: hidden;\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        text-align: center;\n      }\n      #title {\n        color: #ffd34d;\n        font-size: 132px;\n        font-weight: 800;\n        letter-spacing: 2px;\n        /* Pure-CSS keyframes — driven deterministically by HyperFrames'\n           CSS runtime adapter (WAAPI currentTime seeking). No GSAP/CDN. */\n        animation: rise 3s ease-out both;\n      }\n      #subtitle {\n        margin-top: 32px;\n        color: #e8f0ff;\n        font-size: 52px;\n        font-weight: 500;\n        opacity: 0;\n        animation: fade 3s ease-out 0.4s both;\n      }\n      @keyframes rise {\n        0% {\n          opacity: 0;\n          transform: translateY(90px) scale(0.9);\n        }\n        35% {\n          opacity: 1;\n          transform: translateY(0) scale(1);\n        }\n        100% {\n          opacity: 1;\n          transform: translateY(0) scale(1.04);\n        }\n      }\n      @keyframes fade {\n        0% {\n          opacity: 0;\n          transform: translateY(30px);\n        }\n        100% {\n          opacity: 1;\n          transform: translateY(0);\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <div id=\"stage\" data-composition-id=\"demo\" data-duration=\"3\" data-width=\"1920\" data-height=\"1080\">\n      <div id=\"title\" class=\"clip\" data-start=\"0\" data-duration=\"3\">\n        Peninsula School District\n        <span id=\"subtitle\">HyperFrames render smoke</span>\n      </div>\n    </div>\n  </body>\n</html>\n",
