{
  "models": {
    "providers": {
      "bedrock-proxy": {
        "baseUrl": "http://127.0.0.1:18790/v1",
        "api": "openai-completions",
        "auth": "aws-sdk",
        "models": [
          {
            "id": "bedrock-agent",
            "name": "Bedrock Agent (via proxy)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 65535,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "bedrock-proxy/bedrock-agent"
      },
      "workspace": "/home/node/.openclaw"
    }
  },
  "gateway": {
    "port": 3100,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "psd-agent-internal-gateway-token"
    }
  }
}
