{
  "models": {
    "providers": {
      "amazon-bedrock-mantle": {
        "baseUrl": "http://127.0.0.1:18791/v1",
        "api": "openai-completions",
        "auth": "api-key",
        "apiKey": "env:AWS_BEARER_TOKEN_BEDROCK",
        "models": [
          {
            "id": "anthropic.claude-sonnet-5",
            "name": "Claude Sonnet 5 (via Bedrock Mantle)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 1000000,
            "maxTokens": 32768,
            "cost": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 6 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock-mantle/anthropic.claude-sonnet-5"
      },
      "workspace": "/home/node/.openclaw",
      "heartbeat": {
        "every": "0m"
      }
    }
  },
  "tools": {
    "toolSearch": true,
    "deny": ["cron", "nodes", "gateway"]
  },
  "skills": {
    "load": {
      "extraDirs": ["/opt/psd-skills"],
      "watch": false
    }
  },
  "cron": {
    "enabled": false
  },
  "plugins": {
    "entries": {
      "active-memory": {
        "enabled": false
      }
    }
  },
  "gateway": {
    "port": 3100,
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": ["127.0.0.1"],
    "auth": {
      "mode": "token",
      "token": "psd-agent-internal-gateway-token"
    },
    "controlUi": {
      "enabled": false,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": ["*"]
    }
  }
}
