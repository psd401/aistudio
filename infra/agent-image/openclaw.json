{
  "models": {
    "providers": {
      "amazon-bedrock": {
        "baseUrl": "https://bedrock-runtime.us-east-1.amazonaws.com",
        "api": "bedrock-converse-stream",
        "auth": "aws-sdk",
        "models": [
          {
            "id": "us.anthropic.claude-sonnet-5",
            "name": "Claude Sonnet 5 (Bedrock Converse, us. cross-region profile)",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 32768,
            "cost": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 6 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock/us.anthropic.claude-sonnet-5"
      },
      "params": {
        "cacheRetention": "long"
      },
      "workspace": "/home/node/.openclaw",
      "contextTokens": 180000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "1h"
      },
      "heartbeat": {
        "every": "0m"
      },
      "memorySearch": {
        "provider": "bedrock",
        "model": "amazon.titan-embed-text-v2:0"
      }
    }
  },
  "tools": {
    "toolSearch": false,
    "codeMode": {
      "timeoutMs": 60000
    },
    "deny": ["cron", "nodes", "gateway"]
  },
  "skills": {
    "load": {
      "extraDirs": ["/opt/psd-skills"],
      "watch": false
    }
  },
  "cron": {
    "enabled": false
  },
  "plugins": {
    "entries": {
      "active-memory": {
        "enabled": false
      }
    }
  },
  "gateway": {
    "port": 3100,
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": ["127.0.0.1"],
    "auth": {
      "mode": "token",
      "token": "psd-agent-internal-gateway-token"
    },
    "controlUi": {
      "enabled": false,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": ["*"]
    }
  }
}
