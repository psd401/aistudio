{
  "models": {
    "providers": {
      "amazon-bedrock": {
        "baseUrl": "http://127.0.0.1:18790/v1",
        "api": "openai-completions",
        "auth": "aws-sdk",
        "models": [
          {
            "id": "bedrock-agent",
            "name": "Bedrock Agent (via proxy)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 65535,
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock/bedrock-agent"
      },
      "workspace": "/home/node/.openclaw"
    }
  },
  "plugins": {
    "entries": {
      "active-memory": {
        "enabled": true,
        "config": {
          "agents": ["main"],
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 15000,
          "maxSummaryChars": 220,
          "persistTranscripts": false,
          "logging": true
        }
      }
    }
  },
  "gateway": {
    "port": 3100,
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": ["127.0.0.1"],
    "auth": {
      "mode": "token",
      "token": "psd-agent-internal-gateway-token"
    },
    "controlUi": {
      "enabled": false,
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "allowedOrigins": ["*"]
    }
  }
}
