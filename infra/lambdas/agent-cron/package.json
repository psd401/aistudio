    "@aws-sdk/credential-provider-node": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@googleapis/chat": "^5.0.0",
    "@smithy/protocol-http": "^4.0.0",
    "@smithy/signature-v4": "^4.0.0",
    "@aws-sdk/client-rds-data": "^3.0.0"
  },
